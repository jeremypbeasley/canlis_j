.StudioContainer {
  width: 100%;
  background: #242421;
  border-radius: 20vw;
  margin-top: 20vw;
}

.StudioIntro {
  width: 100%;
}

.StudioGrid {
  width: 100%;
  margin: 10vw;
  min-height: 100vh;
}

/* MUURI  */

.grid {
  position: relative;
  margin: 2.5vw;
  min-height: 100vh;
  /* background: blue; */
}
.item {
  /* background: red; */
  display: block;
  position: absolute;
  width: 26.5vw;
  margin: 2.5vw;
  z-index: 1;
}
.item.muuri-item-dragging {
  z-index: 3;
}
.item.muuri-item-releasing {
  z-index: 2;
}
.item.muuri-item-hidden {
  z-index: 0;
}
.item-content {
  position: relative;
  width: 100%;
  height: 100%;
}

.item img {
  border-radius: 10px;
}

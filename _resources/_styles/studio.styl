/* =========================
   STUDIO LAYOUT
   ========================= */

.StudioContainer {
  width: 100%;
  background: #242421;
  border-radius: 15vw;
  margin-top: 20vw;
}

.StudioIntro {
  width: 100%;
}

.StudioGrid {
  width: 100%;
  margin: 5vw;
}

@media (max-width: 768px) {
  .StudioGrid {
    margin: 0;
  }
}

/* =========================
   MUURI GRID WRAPPER
   ========================= */

.grid {
  position: relative;
  margin: 0;
  min-height: 100vh;
}

.item {
  display: block;
  position: absolute;
  width: 18.5vw;
  margin: 2vw 2vw 2vw 2vw;
  z-index: 1;
  border-radius: 10px;
}

.item--large {
  width: 41vw;
}

@media (max-width: 768px) {
  .item, .item--large {
    width: 100vw;
    margin: 0;
  }
}

.item-label {
  margin-top: .9vw;
  height: 4em;
}

@media (max-width: 768px) {
  .item-label {
    margin: 2em;
  }
}

.item.muuri-item-dragging { z-index: 3; }
.item.muuri-item-releasing { z-index: 2; }
.item.muuri-item-hidden { z-index: 0; }

.item__content {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

/* =========================
   ITEM IMAGE
   ========================= */

.item__img {
  width: 100%;
  /* aspect-ratio: 1 / 1; */
  object-fit: fit;
  display: block;
  transform: scale(1.02);
  transition: transform 200ms ease;
  border-radius: 8px;
}

/* =========================
   ITEM OVERLAY
   ========================= */

@media (hover: hover) and (pointer: fine) {
  .item__overlay {
    position: absolute;
    inset: 0;
    display: grid;
    align-items: end;
    padding: 1.8em 2em;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.75),
      rgba(0,0,0,0.60) 60%,
      rgba(0,0,0,.55)
    );

    opacity: 0;
    transform: translateY(6px);

    transition: opacity 200ms ease, transform 200ms ease;
  }
}

@media (hover: none), (pointer: coarse) {
  .item__overlay {
    display: none !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }
}

/* =========================
   OVERLAY CONTENT
   ========================= */

.item__title {
  margin: 0;
  font-size: 1.1rem;
  line-height: 1.2;
}

.item__desc {
  margin: 0;
  opacity: 0.9;
  font-size: 0.95rem;
}


/* =========================
   INTERACTIONS
   ========================= */

.item:hover .item__overlay,
.item:focus-within .item__overlay {
  opacity: 1;
  transform: translateY(0);
  cursor: pointer;
}

.item:hover .item__img,
.item:focus-within .item__img {
  transform: scale(1.03);
}

/* =========================
   ACCESSIBILITY
   ========================= */

@media (prefers-reduced-motion: reduce) {
  .item__img,
  .item__overlay {
    transition: none;
  }
}

/* Splide inside Muuri item */
.item .splide,
.item .splide__track,
.item .splide__list,
.item .splide__slide {
  height: 100%;
}

.item .splide__slide {
  display: block;
}

.item .splide__slide .item__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* =========================
   LIGHTBOX
   ========================= */


.Lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: none;
}

.Lightbox.is-active {
  display: block;
}

.Lightbox__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.88);
}

.Lightbox__panel {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 2rem;
  box-sizing: border-box;
}

.Lightbox__header {
  position: relative;
  flex: 0 0 auto;
  margin-bottom: 1rem;
}

.Lightbox__title {
  color: white;
}

.Lightbox__close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  z-index: 3;
  background: transparent;
  border: 0;
  color: white;
  font-size: 2rem;
  line-height: 1;
  cursor: pointer;
}

.Lightbox__content {
  position: relative;
  z-index: 2;
  flex: 1 1 auto;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
}

.LightboxGallery {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding-bottom: 4rem;
}

.LightboxGallery__item {
  margin: 0;
}

.LightboxGallery__item img {
  display: block;
  width: 60%;
  margin: 0 auto;
  height: auto;
  border-radius: 8px;
}

body.has-lightbox-open {
  overflow: hidden;
}

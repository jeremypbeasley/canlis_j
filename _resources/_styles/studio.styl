/* =========================
   STUDIO LAYOUT
   ========================= */

.StudioContainer {
  width: 100%;
  background: #242421;
  border-radius: 15vw;
  margin-top: 20vw;
}

.StudioIntro {
  width: 100%;
}

.StudioGrid {
  width: 100%;
  margin: 5vw;
}

@media (max-width: 768px) {
  .StudioGrid {
    margin: 0;
  }
}

/* =========================
   MUURI GRID WRAPPER
   ========================= */

.grid {
  position: relative;
  margin: 0;
  min-height: 100vh;
}

.item {
  display: block;
  position: absolute;
  width: 18.5vw;
  margin: 2vw 2vw 2vw 2vw;
  z-index: 1;
  border-radius: 10px;
}

.item--large {
  width: 39.5vw;
}

@media (max-width: 768px) {
  .item, .item--large {
    width: 100vw;
    margin: 0;
  }
}

.item-label {
  margin-top: .9vw;
  height: 4em;
}

@media (max-width: 768px) {
  .item-label {
    margin: 2em;
  }
}

.item.muuri-item-dragging { z-index: 3; }
.item.muuri-item-releasing { z-index: 2; }
.item.muuri-item-hidden { z-index: 0; }

.item__content {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

/* =========================
   ITEM IMAGE
   ========================= */

.item__img {
  width: 100%;
  /* aspect-ratio: 1 / 1; */
  object-fit: fit;
  display: block;
  transform: scale(1.02);
  transition: transform 200ms ease;
  border-radius: 8px;
}

/* =========================
   ITEM OVERLAY
   ========================= */

.item__overlay {
  position: absolute;
  inset: 0;
  display: grid;
  align-items: end;
  padding: 1.8em 2em;
  background: linear-gradient(
    to top,
    rgba(0,0,0,0.75),
    rgba(0,0,0,0.60) 60%,
    rgba(0,0,0,.55)
  );

  opacity: 0;
  transform: translateY(6px);

  transition: opacity 200ms ease, transform 200ms ease;
}

/* =========================
   OVERLAY CONTENT
   ========================= */

.item__title {
  margin: 0;
  font-size: 1.1rem;
  line-height: 1.2;
}

.item__desc {
  margin: 0;
  opacity: 0.9;
  font-size: 0.95rem;
}


/* =========================
   INTERACTIONS
   ========================= */

.item:hover .item__overlay,
.item:focus-within .item__overlay {
  opacity: 1;
  transform: translateY(0);
  cursor: pointer;
}

.item:hover .item__img,
.item:focus-within .item__img {
  transform: scale(1.03);
}

/* =========================
   ACCESSIBILITY
   ========================= */

@media (prefers-reduced-motion: reduce) {
  .item__img,
  .item__overlay {
    transition: none;
  }
}

/* Splide inside Muuri item */
.item .splide,
.item .splide__track,
.item .splide__list,
.item .splide__slide {
  height: 100%;
}

.item .splide__slide {
  display: block;
}

.item .splide__slide .item__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* =========================
   LIGHTBOX
   ========================= */


   .Lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
  }

  .Lightbox.is-active {
    display: block;
  }

  .Lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
  }

  .Lightbox__panel {
    position: relative;
    z-index: 2;
    width: 100vw;
    height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 2rem;
    box-sizing: border-box;
  }

  .Lightbox__close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 20;
    border: 0;
    background: transparent;
    color: white;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
  }

  .Lightbox__header {
    flex: 0 0 auto;
    padding-right: 3.5rem;
    margin-bottom: 1rem;
  }

  .Lightbox__title {
    margin: 0;
    color: white;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .Lightbox__content {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
  }

  .LightboxSplide {
    width: 100%;
    height: 100%;
  }

  .LightboxSplide .splide__track {
    height: 100%;
  }

  .LightboxSplide .splide__list {
    height: 100%;
  }

  .LightboxSplide .splide__slide {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .LightboxSplide .splide__slide img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .LightboxSplide .splide__arrow {
    background: rgba(255, 255, 255, 0.12);
    opacity: 1;
  }

  .LightboxSplide .splide__arrow svg {
    fill: white;
  }

  .LightboxSplide .splide__pagination__page {
    background: rgba(255, 255, 255, 0.45);
  }

  .LightboxSplide .splide__pagination__page.is-active {
    background: white;
  }

  body.has-lightbox-open {
    overflow: hidden;
  }

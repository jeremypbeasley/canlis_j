/* =========================
   STUDIO LAYOUT
   ========================= */

.StudioContainer {
  width: 100%;
  background: #242421;
  border-radius: 15vw;
  margin-top: 20vw;
}

.StudioIntro {
  width: 100%;
}

.StudioGrid {
  width: 100%;
  margin: 5vw;
}

/* =========================
   MUURI GRID WRAPPER
   ========================= */

.grid {
  position: relative;
  margin: 0;
  min-height: 100vh;
  /* background: blue; */
}

.item {
  display: block;
  position: absolute;
  /* width: 26.5vw;
  margin: 2vw; */
  width: 18.5vw;
  margin: 2vw 2vw 2vw 2vw;
  z-index: 1;
  border-radius: 10px;
  /* background: red; */
  /* aspect-ratio: 1 / 1; */

  /* overflow: hidden; */
  /* border-radius: 16px; */
}

.item--square {
  /* aspect-ratio: 1 / 1; */
  /* overflow: visible; */
}

.item--large {
  width: 39.5vw;
  /* aspect-ratio: 1 / 1.125; */
}

.item-label {
  margin-top: .9vw;
  /* background: blue; */
  height: 4em;
}

.item.muuri-item-dragging { z-index: 3; }
.item.muuri-item-releasing { z-index: 2; }
.item.muuri-item-hidden { z-index: 0; }

.item__content {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

/* =========================
   ITEM IMAGE
   ========================= */

.item__img {
  width: 100%;
  /* aspect-ratio: 1 / 1; */
  object-fit: fit;
  display: block;
  transform: scale(1.02);
  transition: transform 200ms ease;
  border-radius: 8px;
}

/* =========================
   ITEM OVERLAY
   ========================= */

.item__overlay {
  position: absolute;
  inset: 0;
  display: grid;
  align-items: end;
  padding: 1.8em 2em;
  background: linear-gradient(
    to top,
    rgba(0,0,0,0.75),
    rgba(0,0,0,0.60) 60%,
    rgba(0,0,0,.55)
  );

  opacity: 0;
  transform: translateY(6px);

  transition: opacity 200ms ease, transform 200ms ease;
}

/* =========================
   OVERLAY CONTENT
   ========================= */

.item__title {
  margin: 0;
  font-size: 1.1rem;
  line-height: 1.2;
}

.item__desc {
  margin: 0;
  opacity: 0.9;
  font-size: 0.95rem;
}


/* =========================
   INTERACTIONS
   ========================= */

.item:hover .item__overlay,
.item:focus-within .item__overlay {
  opacity: 1;
  transform: translateY(0);
  cursor: pointer;
}

.item:hover .item__img,
.item:focus-within .item__img {
  transform: scale(1.03);
}

/* =========================
   ACCESSIBILITY
   ========================= */

@media (prefers-reduced-motion: reduce) {
  .item__img,
  .item__overlay {
    transition: none;
  }
}

/* Splide inside Muuri item */
.item .splide,
.item .splide__track,
.item .splide__list,
.item .splide__slide {
  height: 100%;
}

.item .splide__slide {
  display: block;
}

.item .splide__slide .item__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

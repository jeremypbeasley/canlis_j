/* =========================
   STUDIO LAYOUT
   ========================= */


 .StudioContainer {
   width: 100%;
   background: #242421;
   border-radius: 15vw;
   margin-top: 30vw;
   transform: translateY(100vh);
   animation: StudioLoad 1000ms ease 5000ms forwards;
 }

 @keyframes StudioLoad {
   from {
     transform: translateY(100vh);
     opacity: 0;
   }
   to {
     transform: translateY(0);
     opacity: 1;
   }
 }

.StudioIntro {
  width: 100%;
}

.StudioGrid {
  width: 100%;
  margin: 5vw;
}

@media (max-width: 768px) {
  .StudioGrid {
    margin: 0;
  }
}



/* =========================
   MUURI GRID WRAPPER
   ========================= */

.grid {
  position: relative;
  margin: 0;
  min-height: 100vh;
}

.item {
  display: block;
  position: absolute;
  width: 18.5vw;
  margin: 2vw 2vw 2vw 2vw;
  z-index: 1;
  border-radius: 10px;
  cursor: pointer;
}

.item--large {
  width: 41vw;
}

@media (max-width: 768px) {
  .item, .item--large {
    width: 100vw;
    margin: 0;
  }
}

.item-label {
  margin-top: .9vw;
  height: 4em;
}

@media (max-width: 768px) {
  .item-label {
    margin: 2em;
  }
}

.item__button {
  display: block;
  width: 100%;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  appearance: none;
  -webkit-appearance: none;
  cursor: pointer;
  text-align: left;
}

.item.muuri-item-dragging { z-index: 3; }
.item.muuri-item-releasing { z-index: 2; }
.item.muuri-item-hidden { z-index: 0; }

.item__content {
  position: relative;
  width: 100%;
  overflow: hidden;
}

/* =========================
   ITEM IMAGE
   ========================= */

.item__img {
  width: 100%;
  height: auto;
  display: block;
  transform: scale(1.02);
  transition: transform 200ms ease;
  border-radius: 8px;
}

/* =========================
   ITEM OVERLAY
   ========================= */

@media (hover: hover) and (pointer: fine) {
  .item__overlay {
    position: absolute;
    inset: 0;
    display: grid;
    align-items: end;
    padding: 1.8em 2em;
    cursor: pointer;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.75),
      rgba(0,0,0,0.60) 60%,
      rgba(0,0,0,.55)
    );

    opacity: 0;
    transform: translateY(6px);

    transition: opacity 200ms ease, transform 200ms ease;
  }
}

@media (hover: none), (pointer: coarse) {
  .item__overlay {
    display: none !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }
}

/* =========================
   OVERLAY CONTENT
   ========================= */

.item__title {
  margin: 0;
  font-size: 1.1rem;
  line-height: 1.2;
}

.item__desc {
  margin: 0;
  opacity: 0.9;
  font-size: 0.95rem;
  cursor: pointer;
}

/* =========================
   INTERACTIONS
   ========================= */

.item:hover .item__overlay,
.item:focus-within .item__overlay {
  opacity: 1;
  transform: translateY(0);
  cursor: pointer;
}

.item:hover .item__img,
.item:focus-within .item__img {
  transform: scale(1.03);
}

/* =========================
   ACCESSIBILITY
   ========================= */

@media (prefers-reduced-motion: reduce) {
  .item__img,
  .item__overlay {
    transition: none;
  }
}

/* Splide inside Muuri item */
.item .splide,
.item .splide__track {
  width: 100%;
}

.item .splide__list,
.item .splide__slide {
  height: auto;
}

.item .splide__slide {
  display: block;
}

.item .splide__slide .item__img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

/* =========================
   LIGHTBOX
   ========================= */
   .Lightbox {
     position: fixed;
     inset: 0;
     z-index: 9999;
     opacity: 0;
     visibility: hidden;
     pointer-events: none;
     transition: opacity 180ms ease, visibility 180ms ease, transform 180ms ease;
     /* transform: translateY(-1vw); */
   }

   .Lightbox.is-open {
     opacity: 1;
     visibility: visible;
     pointer-events: auto;
     /* transform: scale(1) translateY(0); */
   }

    .LightboxOverlay {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
      padding: 0;
      margin: 0;
      background: rgba(255,255,255, 0.9);
      cursor: pointer;
    }

    .LightboxShell {
      position: relative;
      z-index: 2;
      /* width: calc(100% - 16vw); */
      width: 100%;
      /* margin: 8vw; */
      border-radius: 1vw;
      /* height: calc(100vh - 16vw); */
      height: 100%;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      background: #242421;
      padding: 4vw;
      overflow: auto;            /* or overflow-y: scroll */
      scrollbar-width: none;     /* Firefox */
      -ms-overflow-style: none;  /* IE/Edge legacy */
    }

    @media (max-width: 768px) {
      .LightboxShell {
        padding: 0;
      }
    }

    .LightboxShell::-webkit-scrollbar {
      display: none;             /* Chrome, Safari */
    }

    .LightboxClose {
      position: fixed;
      top: 24px;
      right: 24px;
      z-index: 20;
      border: 0;
      background: white;
      color: #f2eee6;
      font: inherit;
      letter-spacing: 0.04em;
      cursor: pointer;
      padding: 0;
      text-indent: 1000px;
      height: 2vw;
      width: 2vw;
      background: url("/uploads/close.svg") no-repeat center / cover;
      transition: transform 100ms ease;
    }

    @media (max-width: 768px) {
      .LightboxClose {
        height: 6vw;
        width: 6vw;
      }
    }

    .LightboxClose:hover {
      transform: scale(1.15);
    }

    .LightboxItems {
      min-height: 100%;
      opacity: 0;
      transition: opacity 300ms ease 400ms, visibility 180ms ease, transform 300ms ease 300ms;
      transform: scale(.98) translateY(4vw);
    }

    .LightboxItems.is-open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: scale(1) translateY(0);
    }

    .LightboxItem {
      width: 100%;
      min-height: 100%;
    }

    .LightboxItemInner {
      position: relative
      z-index: 3
      width: 100%
      max-width: 1400px
      margin: 0 auto
      /* padding: 72px 0 48px */
      display: grid
      grid-template-columns: minmax(0, 1fr) 360px
      gap: 36px
      align-items: start

    }

    @media (max-width: 991px) {
      .LightboxItemInner {
        width:100%
        /* padding: 72px 0 32px */
        grid-template-columns: 1fr
        gap: 28px
      }
    }

    .LightboxMedia {
      display: flex;
      flex-direction: column;
      gap: 24px;
      min-width: 0;
    }

    .LightboxFigure {
      margin: 0;
    }

    .LightboxFigure img {
      display: block;
      width: 100%;
      height: auto;
      /* border-radius: 18px; */
    }

    .LightboxCaption {
      margin-top: 10px;
      color: rgba(242, 238, 230, 0.8);
      font-size: 14px;
      line-height: 1.4;
    }

    .LightboxMeta {
      min-width: 0;
    }

    @media (max-width: 768px) {
      .LightboxMeta {
        min-width: 0;
        padding: 6vw;
      }
    }



    .LightboxMetaSticky {
      position: sticky;
      top: 72px;
      color: #f2eee6;
    }

    .LightboxDesc {
      margin-bottom: 28px;
      color: rgba(242, 238, 230, 0.88);
      line-height: 1.55;
    }

    .LightboxFacts {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .LightboxFact {
      padding-top: 14px;
      /* border-top: 1px solid rgba(242, 238, 230, 0.18); */
    }

    .LightboxLabel {
      margin-bottom: 4px;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(242, 238, 230, 0.55);
    }

    .LightboxValue {
      color: #f2eee6;
      line-height: 1.45;
    }

    .LightboxActions {
      padding-top: 8px;
    }

    .LightboxButton {
      display: inline-block;
      padding: 12px 18px;
      border: 1px solid rgba(242, 238, 230, 0.25);
      border-radius: 999px;
      color: #f2eee6;
      text-decoration: none;
      transition: background 180ms ease, border-color 180ms ease;
    }

    .LightboxButton:hover {
      background: rgba(242, 238, 230, 0.08);
      border-color: rgba(242, 238, 230, 0.45);
    }

    /* body.lightbox-open {
      overflow: hidden;
    } */

    @media (max-width: 991px) {
      .LightboxItemInner {
        width: 100%;
        padding: 72px 0 32px;
        grid-template-columns: 1fr;
        gap: 28px;
      }

      .LightboxMetaSticky {
        position: static;
      }

      .LightboxClose {
        top: 18px;
        right: 16px;
      }
    }


/* =========================
   COLLECTION LIGHTBOX
   ========================= */

.LightboxCollection {
  position: sticky;
  z-index: 3;
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 360px;
  gap: 36px;
  align-items: start;
}

.LightboxCollectionItems {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 32px;
}

.LightboxCollectionEntry {
  margin: 0;
}

.LightboxCollectionEntry + .LightboxCollectionEntry {
  padding-top: 32px;
  border-top: 1px solid rgba(242, 238, 230, 0.12);
}

.LightboxCollectionEntryMedia {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.LightboxCollectionEntryMedia .LightboxFigure img {
  width: 100%;
  height: auto;
  display: block;
  /* border-radius: 18px; */
}

.LightboxCollectionMeta {
  min-width: 0;
  position: sticky;
}

.LightboxLabel--Collection {
  display: block;
  margin-bottom: 12px;
}

@media (max-width: 991px) {
  .LightboxCollection {
    width: calc(100% - 32px);
    padding: 72px 0 32px;
    grid-template-columns: 1fr;
    gap: 28px;
  }

  .LightboxCollectionMeta {
    grid-row: 1;
  }

  .LightboxCollectionItems {
    grid-row: 2;
  }
}


.LightboxCollectionEntryMeta {
  width: 100%;
  max-width: 720px;
  margin-top: 18px;
}

.LightboxEntryTitle {
  margin: 0 0 14px;
  font-size: clamp(22px, 2.2vw, 30px);
  line-height: 1.08;
  font-weight: 400;
  color: #f2eee6;
}

.LightboxCollectionEntryMeta .LightboxDesc {
  margin-bottom: 22px;
}

.LightboxCollectionEntryMeta .LightboxFacts {
  max-width: 560px;
}

.LightboxCollectionEntryMeta .LightboxFact:first-child {
  /* border-top: 1px solid rgba(242, 238, 230, 0.18); */
}

@media (max-width: 991px) {
  .LightboxCollectionEntryMeta {
    max-width: 100%;
    margin-top: 14px;
  }

  .LightboxCollectionEntryMeta .LightboxFacts {
    max-width: 100%;
  }
}

/* FLASH . */

.Flasher {
  width: 25vw;
  height: 25vw;
  position: fixed;
  top: 20vw;
  left: 40vw;
  overflow: hidden;
  border-radius: 10000vw;
  opacity: 1;
  transition: opacity 400ms ease;
  transform: scale(0);
  animation: scaleIn 1000ms ease forwards;
}

@keyframes scaleIn {
    0%   { transform: scale(0); }
    60%  { transform: scale(1.05); }
    80%  { transform: scale(0.98); }
    100% { transform: scale(1); }
}

.Flasher.is-done {
  opacity: 0;
  pointer-events: none;
}


@media (max-width: 768px) {
  .Flasher {
    width: 80vw;
    height: 80vw;
    position: fixed;
    top: 60vw;
    left: 10vw;
  }
}

.Flasher .splide {
  overflow: hidden;
  transform: scale(1.2);
}

.Flasher .splide__slide {
  width: 100%;
  height: 100%;
  display: flex;
}

.Flasher .splide__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.Flasher .splide,
.Flasher .splide__track,
.Flasher .splide__list,
.Flasher .splide__slide {
  width: 100%;
  height: 100%;
}

.Flasher .splide__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}
